# Immopro Central — Backend
# Copier vers .env et adapter les valeurs.

DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
USE_SQLITE=True

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (si USE_SQLITE=False)
POSTGRES_DB=immopro
POSTGRES_USER=immopro
POSTGRES_PASSWORD=immopro
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Frontend (liens reset password)
FRONTEND_URL=http://localhost:3000
DEFAULT_FROM_EMAIL=noreply@immopro.cm
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
